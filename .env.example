# ─── NOTION ───────────────────────────────────────────────────────────────────
# Crie sua integração em: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs dos bancos de dados (pegue na URL do banco no Notion)
# Ex: https://notion.so/workspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ este é o ID
NOTION_CONTEUDOS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_IDEIAS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RELATORIOS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── YOUTUBE ──────────────────────────────────────────────────────────────────
# Crie sua API Key em: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do canal: acesse seu canal, está na URL /channel/UCxxxxxx
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxx

# ─── INSTAGRAM ────────────────────────────────────────────────────────────────
# Token de acesso da Graph API (conta Business/Creator + Facebook Page)
# Guia: https://developers.facebook.com/docs/instagram-basic-display-api
INSTAGRAM_ACCESS_TOKEN=IGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do usuário: retornado pela API ao autenticar
INSTAGRAM_USER_ID=xxxxxxxxxxxxxxxxx
